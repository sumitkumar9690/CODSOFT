<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>Your Shopping Cart</title>
		<link rel="stylesheet" href="style.css" />
	</head>
	<body>
		<header
			style="
				display: flex;
				justify-content: space-between;
				align-items: center;
				padding: 20px 40px;
			"
		>
			<h1>Your Shopping Cart</h1>
			<a
				href="index.html"
				style="color: white; text-decoration: none; font-weight: bold"
				>Continue Shopping</a
			>
		</header>

		<main class="cart-container">
			<div id="cart-items-list" class="cart-items-list"></div>

			<div class="bill-summary-card">
				<h3 class="summary-title">Bill Summary</h3>
				<hr class="detail-divider" />

				<div class="summary-row">
					<span>Items Subtotal</span>
					<span id="subtotal-val">$0.00</span>
				</div>
				<div class="summary-row text-green">
					<span>Discount Savings</span>
					<span id="discount-val">-$0.00</span>
				</div>
				<div class="summary-row text-green">
					<span>Shipping Fee</span>
					<span>FREE</span>
				</div>

				<hr class="detail-divider" />

				<div class="summary-row total-row">
					<span>Total Payable</span>
					<span id="total-val">$0.00</span>
				</div>

				<button class="view-btn checkout-btn">Proceed to Checkout</button>
			</div>
		</main>

		<script src="cart.js"></script>
	</body>
</html>
